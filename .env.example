# Database
DATABASE_URL="postgresql://itflow:CHANGE_ME@db:5432/itflow?schema=public"

# Database password (used by docker-compose.prod.yml)
DB_PASSWORD="CHANGE_ME"

# NextAuth - generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME"

# NextAuth - your public URL (with https in production)
NEXTAUTH_URL="https://your-domain.com"

# SMTP - Email settings for portal invitations and notifications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="ITFlow <noreply@your-domain.com>"

# Inbound Email - Secret token for email-to-ticket webhook
INBOUND_EMAIL_SECRET="CHANGE_ME"

# Resend - bestel-mail (fase 5)
RESEND_API_KEY=
ORDER_MAIL_FROM="ITFlow <noreply@itfin.nl>"
ORDER_MAIL_TO=administratie@itfin.nl

# Maandrapportage per mail (deploy/monthly-report)
# Gedeeld geheim tussen de app en de systemd-timer die het rapport triggert.
REPORT_CRON_SECRET=CHANGE_ME
# Ontvanger van de maandrapportage; valt terug op ORDER_MAIL_TO als leeg.
REPORT_MAIL_TO=administratie@itfin.nl

# Web push (telefoonmeldingen). Genereer een keypaar met:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:administratie@itfin.nl
